@{
    ViewData["Title"] = "CardDemo - Main Menu";
    var userName = ViewBag.UserName as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">CardDemo</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, @userName</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-12">
                <h2 class="mb-4">Main Menu</h2>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Account Management</h5>
                        <p class="card-text">View and update account information</p>
                        <a asp-controller="AccountManagement" asp-action="Index" asp-route-accountId="10000000001" class="btn btn-primary">Accounts</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Credit Cards</h5>
                        <p class="card-text">Manage credit cards</p>
                        <a asp-controller="CardManagement" asp-action="Index" asp-route-accountId="10000000001" class="btn btn-primary">Cards</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Transactions</h5>
                        <p class="card-text">View and process transactions</p>
                        <a asp-controller="TransactionManagement" asp-action="Index" asp-route-accountId="10000000001" class="btn btn-primary">Transactions</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Reports</h5>
                        <p class="card-text">Generate transaction reports</p>
                        <a href="#" class="btn btn-primary">Reports</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Bill Payment</h5>
                        <p class="card-text">Make bill payments</p>
                        <a href="#" class="btn btn-primary">Payments</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Statements</h5>
                        <p class="card-text">View account statements</p>
                        <a href="#" class="btn btn-primary">Statements</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
