@model IEnumerable<CardDemo.Core.Entities.Transaction>
@{
    ViewData["Title"] = "Transactions";
    var userName = ViewBag.UserName as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">CardDemo</a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">Welcome, @userName</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Transactions</h2>
            <div>
                <a asp-action="Create" class="btn btn-primary">Add Transaction</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Menu</a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Transaction ID</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Merchant</th>
                            <th>Posted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model)
                        {
                            <tr>
                                <td>@transaction.TransactionId</td>
                                <td>@transaction.TransactionDate.ToString("MM/dd/yyyy")</td>
                                <td>@transaction.TransactionType</td>
                                <td>@transaction.TransactionCategory</td>
                                <td>@transaction.TransactionAmount.ToString("C")</td>
                                <td>@transaction.MerchantName</td>
                                <td>
                                    @if (transaction.PostedIndicator)
                                    {
                                        <span class="badge bg-success">Posted</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@transaction.TransactionId" class="btn btn-sm btn-info">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                No transactions found. This is a demo - in production, transactions would be linked to your accounts.
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
